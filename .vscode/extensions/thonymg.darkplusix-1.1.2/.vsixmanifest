    <Tags>default theme,theme,dark,dark plus,visual studio,color-theme,javascript</Tags>
    <Categories>Themes</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Badges><Badge Link="https://marketplace.visualstudio.com/items/thonymg.Darkplusix" ImgUri="http://vsmarketplacebadge.apphb.com/version/thonymg.Darkplusix.svg" Description="Extension version" /><Badge Link="https://marketplace.visualstudio.com/items/thonymg.Darkplusix" ImgUri="http://vsmarketplacebadge.apphb.com/installs/thonymg.Darkplusix.svg" Description="Extension installs" /><Badge Link="https://marketplace.visualstudio.com/items/thonymg.Darkplusix" ImgUri="http://vsmarketplacebadge.apphb.com/rating/thonymg.Darkplusix.svg" Description="Extension Rating" /></Badges>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Code.Engine" Value="*" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="" />
      
        <Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://github.com/thonymg/vscode-darkplusix" />
        <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/thonymg/vscode-darkplusix" />
        
          <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/thonymg/vscode-darkplusix" />
        
      
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/thonymg/vscode-darkplusix/issues" />
