  <Metadata>
    <Identity Language="en-US" Id="dark-plus-one-monokai" Version="0.2.0" Publisher="Geobomatic"/>
    <DisplayName>Dark+ One Monokai</DisplayName>
    <Description xml:space="preserve">A mashup between VSCode&#39;s Dark+ theme and Joshua Azemoh&#39;s One Monokai syntax colours</Description>
    <Tags>Vscode,Theme,Onedark,Monokai,Dark+,semantic,theme,color-theme</Tags>
    <Categories>Themes</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Badges></Badges>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Code.Engine" Value="^1.44.0" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.LocalizedLanguages" Value="" />
      
        <Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://github.com/Geobert/dark-plus-one-monokai.git" />
        <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/Geobert/dark-plus-one-monokai.git" />
        
          <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/Geobert/dark-plus-one-monokai.git" />
        
      
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/Geobert/dark-plus-one-monokai/issues" />
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://github.com/Geobert/dark-plus-one-monokai/blob/master/README.md" />
      
      
      <Property Id="Microsoft.VisualStudio.Services.GitHubFlavoredMarkdown" Value="true" />
      
      
    </Properties>
    <License>extension/LICENSE.txt</License>
    <Icon>extension/icon.png</Icon>
